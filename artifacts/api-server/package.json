{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cd /home/runner/workspace && uv run uvicorn main:app --host 0.0.0.0 --port ${PORT:-8080} --reload --app-dir /home/runner/workspace/backend",
    "build": "cd /home/runner/workspace && uv sync",
    "start": "cd /home/runner/workspace && uv run uvicorn main:app --host 0.0.0.0 --port ${PORT:-8080} --app-dir /home/runner/workspace/backend",
    "typecheck": "echo 'No typecheck needed for Python backend'"
  },
  "dependencies": {},
  "devDependencies": {}
}
